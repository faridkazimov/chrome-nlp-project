{
  "manifest_version": 3,
  "name": "NLP Text Analyzer",
  "version": "1.0",
  "description": "Analyze selected text with NLP - sentiment, classification, and named entities.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
